{
  "name": "whitestuff-automation",
  "version": "1.0.0",
  "description": "White Stuff E2E Playwright Automation",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke/",
    "test:e2e": "playwright test tests/e2e/",
    "test:smoke:dev": "TEST_ENV=dev playwright test tests/smoke/",
    "test:smoke:staging": "TEST_ENV=staging playwright test tests/smoke/",
    "test:e2e:dev": "TEST_ENV=dev playwright test tests/e2e/",
    "test:e2e:staging": "TEST_ENV=staging playwright test tests/e2e/",
    "test:e2e:prod": "TEST_ENV=prod playwright test tests/e2e/",
    "test:desktop": "TEST_ENV=prod playwright test tests/e2e/DesktopMenuFlow.spec.ts --headed",
    "test:women": "TEST_ENV=prod playwright test tests/e2e/WomenFlow.spec.ts --headed",
    "codegen": "playwright codegen https://www.whitestuff.com",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "allure-playwright": "^2.9.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
